# NERVE Environment Configuration

# SingleStore (local dev)
SINGLESTORE_HOST=127.0.0.1
SINGLESTORE_PORT=3306
SINGLESTORE_USER=root
SINGLESTORE_PASSWORD=password
SINGLESTORE_DATABASE=nerve

# SingleStore Cloud (for cloud deploy - you fill these in)
# SINGLESTORE_HOST=your-cluster.svc.singlestore.com
# SINGLESTORE_PORT=3306
# SINGLESTORE_USER=admin
# SINGLESTORE_PASSWORD=your-password

# Anthropic / Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# App config
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:3000

# Autonomous engine
AUTONOMOUS_LOOP_INTERVAL_SECONDS=5

# SingleStore Analyst API (for "Ask NERVE" chat pane)
# Get the endpoint URL and key from SingleStore Portal → Analyst → Domain Settings → API Keys
ANALYST_API_URL=https://apps.us-east-1.cloud.singlestore.com/v1/organizations/{orgID}/projects/{projectID}
ANALYST_API_KEY=your-analyst-api-key-here

# S3 Pipeline (for SingleStore Pipelines ingestion)
# S3_BUCKET_PATH=your-bucket-name/nerve
# S3_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
